{
  "manifest_version": 2,
  "name": "Clipboard Manager",
  "version": "1.0",
  "description": "Simple clipboard history and text snippets manager",
  "permissions": [
    "activeTab",
    "storage",
    "*://else.fcim.utm.md/*",
    "*://generativelanguage.googleapis.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "clipboard-manager@tools.browser"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://else.fcim.utm.md/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Clipboard Manager"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }
}
